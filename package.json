{
  "name": "chainsight",
  "version": "0.6.0",
  "description": "AML risk scoring engine for cryptocurrency wallets. Web app + CLI. Analyses Ethereum addresses against FATF typologies (sanctions, mixer, scam, layering, peel chains) and produces auditable risk reports.",
  "private": true,
  "type": "module",
  "bin": {
    "chainsight": "bin/cli.ts"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "cli": "tsx bin/cli.ts",
    "scan": "tsx bin/cli.ts scan",
    "rescan": "tsx bin/rescan-watchlist.ts",
    "sync:ofac": "tsx scripts/sync-ofac.ts",
    "sync:eu": "tsx scripts/sync-eu.ts",
    "sync:uk": "tsx scripts/sync-uk.ts",
    "sync:un": "tsx scripts/sync-un.ts",
    "sync:all": "npm run sync:ofac && npm run sync:eu && npm run sync:uk && npm run sync:un",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "aml",
    "compliance",
    "cryptocurrency",
    "ethereum",
    "risk-scoring",
    "fatf",
    "ofac",
    "blockchain-analytics",
    "regtech"
  ],
  "author": "Jorge Fernandez Gonzalez",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "d3-force": "^3.0.0",
    "dotenv": "^16.4.5",
    "jose": "^6.2.3",
    "next": "^16.2.4",
    "nodemailer": "^8.0.7",
    "p-queue": "^8.0.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-2d": "^1.29.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
