{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build --webpack",
  "functions": {
    "app/api/scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/sync-sanctions/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-sanctions",
      "schedule": "0 2 * * *"
    }
  ]
}
